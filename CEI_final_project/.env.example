# Rename this file to .env and fill in your real keys.
# Never commit the real .env file to GitHub.

OPENAI_API_KEY=your_openai_api_key_here

# Optional: a GitHub personal access token raises your API rate limit
# from 60 requests/hour to 5000 requests/hour. Not required for small pulls.
GITHUB_TOKEN=your_github_token_here

# Repo this pipeline indexes
GITHUB_REPO=fastapi/fastapi
